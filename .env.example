# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-min-32-chars

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Database
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/whiteboard?retryWrites=true&w=majority

# WebSocket Server (set to Railway URL in production)
NEXT_PUBLIC_WS_SERVER_URL=http://localhost:3001
WS_PORT=3001

# Shared JWT secret (must match NEXTAUTH_SECRET)
JWT_SECRET=your-secret-here-min-32-chars

# CORS — comma-separated allowed origins for ws-server
CORS_ORIGIN=http://localhost:3000
